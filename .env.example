# Database - PostgreSQL
DATABASE_URL="<YOUR_DATABASE_URL>"
POSTGRES_DB="<YOUR_DB_NAME>"
POSTGRES_USER="<YOUR_DB_USER>"
POSTGRES_PASSWORD="<YOUR_DB_PASSWORD>"

# Data directory for container volumes
DATA_DIR="<YOUR_DATA_DIR>"

# Chroma Vector Database
CHROMA_HOST="<YOUR_CHROMA_HOST>"
CHROMA_PORT="<YOUR_CHROMA_PORT>"
CHROMA_COLLECTION="<YOUR_CHROMA_COLLECTION>"
CHROMA_AUTH_TOKEN="<YOUR_CHROMA_AUTH_TOKEN>"

# JWT
JWT_SECRET="<YOUR_JWT_SECRET>"
JWT_EXPIRES_IN="<YOUR_JWT_EXPIRES_IN>"

# LLM - Alibaba Cloud 百炼
OPENAI_API_KEY_DASHSCOPE="<YOUR_DASHSCOPE_API_KEY>"
LLM_BASE_URL="<YOUR_LLM_BASE_URL>"
LLM_MODEL="<YOUR_LLM_MODEL>"
EMBEDDING_MODEL="<YOUR_EMBEDDING_MODEL>"

# LLM - DeepSeek (预留)
OPENAI_API_KEY_DEEPSEEK="<YOUR_DEEPSEEK_API_KEY>"

# App
PORT=<YOUR_PORT>
NEXT_PUBLIC_APP_URL="<YOUR_APP_URL>"
NODE_ENV="<YOUR_NODE_ENV>"

# Knowledge Base Logging
KB_LOG_DIR="<YOUR_KB_LOG_DIR>"
KB_LOG_FILE="<YOUR_KB_LOG_FILE>"
KB_ENABLE_FILE_LOG="<YOUR_KB_ENABLE_FILE_LOG>"

# Agent Logging
AGENT_LOG_DIR="<YOUR_AGENT_LOG_DIR>"
AGENT_LOG_FILE="<YOUR_AGENT_LOG_FILE>"
AGENT_ENABLE_FILE_LOG="<YOUR_AGENT_ENABLE_FILE_LOG>"

# QWeather JWT认证 (项目: farm-agent)
# 凭据ID (kid)
QWEATHER_JWT_KID=<YOUR_QWEATHER_KID>
# 项目ID (sub)
QWEATHER_JWT_SUB=<YOUR_QWEATHER_SUB>
# Ed25519私钥文件路径
QWEATHER_JWT_PRIVATE_KEY_PATH="<YOUR_PRIVATE_KEY_PATH>"
# API Host
QWEATHER_API_HOST="<YOUR_QWEATHER_API_HOST>"
